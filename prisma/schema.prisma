// Prisma schema for Online Auto Abmelden Admin Dashboard

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────────
// Admin users
// ──────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Customers (extracted from orders)
// ──────────────────────────────────────────────
model Customer {
  id               String    @id @default(cuid())
  email            String    @unique
  firstName        String    @default("")
  lastName         String    @default("")
  phone            String    @default("")
  city             String    @default("")
  postcode         String    @default("")
  address          String    @default("")
  street           String    @default("")
  country          String    @default("DE")
  totalOrders      Int       @default(0)
  totalSpent       Float     @default(0)
  password         String?
  emailSubscribed  Boolean   @default(true)
  unsubscribeToken String    @default("")
  lastLoginAt      DateTime?
  orders           Order[]
  invoices         Invoice[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([createdAt])
  @@index([firstName, lastName])
  @@index([emailSubscribed])
}

// ──────────────────────────────────────────────
// Orders
// ──────────────────────────────────────────────
model Order {
  id              String    @id @default(cuid())
  orderNumber     Int       @unique
  wpOrderId       Int?      @unique
  status          String    @default("pending")
  total           Float     @default(0)
  subtotal        Float     @default(0)
  paymentFee      Float     @default(0)
  discountAmount  Float     @default(0)
  couponCode      String    @default("")
  currency        String    @default("EUR")
  paymentMethod   String    @default("")
  paymentTitle    String    @default("")
  transactionId   String    @default("")
  billingEmail    String    @default("")
  billingPhone    String    @default("")
  billingFirst    String    @default("")
  billingLast     String    @default("")
  billingStreet   String    @default("")
  billingCity     String    @default("")
  billingPostcode String    @default("")
  serviceData     String    @default("{}")
  productName     String    @default("")
  productId       Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerId      String?
  items           OrderItem[]
  notes           OrderNote[]
  payments        Payment[]
  invoices        Invoice[]
  documents       OrderDocument[]
  messages        OrderMessage[]
  datePaid        DateTime?
  dateCompleted   DateTime?
  completionEmailSent Boolean @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([billingEmail])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([deletedAt, status])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, status, createdAt])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName String
  productId   Int?
  quantity    Int    @default(1)
  price       Float  @default(0)
  total       Float  @default(0)
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  note      String
  author    String   @default("system")
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────
// Order messages (admin → customer communication)
// ──────────────────────────────────────────────
model OrderMessage {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  message     String
  attachments String   @default("[]")
  sentBy      String   @default("admin")
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Order documents (PDFs uploaded by admin)
// ──────────────────────────────────────────────
model OrderDocument {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  Int      @default(0)
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ──────────────────────────────────────────────
// Blog posts
// ──────────────────────────────────────────────
model BlogPost {
  id              String    @id @default(cuid())
  wpPostId        Int?      @unique
  slug            String    @unique
  title           String
  content         String
  excerpt         String    @default("")
  featuredImage   String    @default("")
  featuredImageId String    @default("")
  status          String    @default("draft")
  author          String    @default("Admin")
  metaTitle       String    @default("")
  metaDescription String    @default("")
  focusKeyword    String    @default("")
  canonical       String    @default("")
  robots          String    @default("index, follow")
  ogTitle         String    @default("")
  ogDescription   String    @default("")
  ogImage         String    @default("")
  category        String    @default("")
  tags            String    @default("")
  views           Int       @default(0)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([status, scheduledAt])
  @@index([createdAt])
  @@index([status, createdAt])
}

// ──────────────────────────────────────────────
// Products / Services
// ──────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  wpProductId Int?     @unique
  name        String
  slug        String   @unique
  description String   @default("")
  price       Float    @default(0)
  isActive    Boolean  @default(true)
  serviceType String   @default("")
  options     String   @default("[]")

  // Rich content for the dynamic product page
  content       String   @default("")
  heroTitle     String   @default("")
  heroSubtitle  String   @default("")
  featuredImage String   @default("")
  faqItems      String   @default("[]")

  // SEO fields
  metaTitle       String @default("")
  metaDescription String @default("")
  canonical       String @default("")
  robots          String @default("index, follow")
  ogTitle         String @default("")
  ogDescription   String @default("")
  ogImage         String @default("")

  // Form configuration
  formType      String   @default("")   // 'abmeldung', 'anmeldung', or '' for no form

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([isActive])
  @@index([serviceType])
}

// ──────────────────────────────────────────────
// Payment gateways configuration
// ──────────────────────────────────────────────
model PaymentGateway {
  id          String   @id @default(cuid())
  gatewayId   String   @unique
  name        String
  description String   @default("")
  isEnabled   Boolean  @default(false)
  fee         Float    @default(0)
  apiKey      String   @default("")
  secretKey   String   @default("")
  mode        String   @default("live")
  icon        String   @default("")
  sortOrder   Int      @default(0)
  settings    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Payments / Transactions
// ──────────────────────────────────────────────
model Payment {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gatewayId     String
  transactionId String    @default("")
  amount        Float
  currency      String    @default("EUR")
  status        String    @default("pending")
  method        String    @default("")
  providerData  String    @default("{}")
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orderId])
  @@index([status])
}

// ──────────────────────────────────────────────
// Site settings (key-value store)
// ──────────────────────────────────────────────
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
  group String @default("general")

  @@index([group])
}

// ──────────────────────────────────────────────
// Site Pages (WordPress pages with Rank Math SEO)
// ──────────────────────────────────────────────
model Page {
  id              String    @id @default(cuid())
  wpPageId        Int?      @unique
  slug            String    @unique
  title           String
  content         String
  excerpt         String    @default("")
  status          String    @default("draft")
  author          String    @default("iKFZ-Team")
  template        String    @default("")
  parent          Int       @default(0)
  menuOrder       Int       @default(0)
  featuredImage   String    @default("")

  // Rank Math SEO fields
  metaTitle       String    @default("")
  metaDescription String    @default("")
  focusKeywords   String    @default("")
  seoScore        Int       @default(0)
  canonical       String    @default("")
  robots          String    @default("index, follow")
  schemaType      String    @default("")
  schemaData      String    @default("")

  // Open Graph
  ogTitle         String    @default("")
  ogDescription   String    @default("")
  ogImage         String    @default("")
  ogType          String    @default("article")

  // Twitter Card
  twitterTitle    String    @default("")
  twitterDescription String @default("")
  twitterImage    String    @default("")
  twitterCard     String    @default("summary_large_image")

  // Internal links tracking
  internalLinks   Int       @default(0)
  externalLinks   Int       @default(0)

  // Page classification
  isFooterPage    Boolean   @default(false)
  pageType        String    @default("page")  // page, footer, legal

  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([seoScore])
}


// ──────────────────────────────────────────────
// Categories (from WordPress)
// ──────────────────────────────────────────────
model Category {
  id          String @id @default(cuid())
  wpCatId     Int?   @unique
  name        String
  slug        String @unique
  description String @default("")
  count       Int    @default(0)
  parent      Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ──────────────────────────────────────────────
// Tags (from WordPress)
// ──────────────────────────────────────────────
model Tag {
  id          String @id @default(cuid())
  wpTagId     Int?   @unique
  name        String
  slug        String @unique
  description String @default("")
  count       Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ──────────────────────────────────────────────
// Invoices (Rechnungen)
// ──────────────────────────────────────────────
model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  // Billing info (snapshot from order)
  billingName     String    @default("")
  billingEmail    String    @default("")
  billingAddress  String    @default("")
  billingCity     String    @default("")
  billingPostcode String    @default("")
  billingCountry  String    @default("DE")

  // Company details (for business invoices)
  companyName     String    @default("")
  companyTaxId    String    @default("")

  // Line items (JSON array)
  items           String    @default("[]")

  // Amounts
  subtotal        Float     @default(0)
  taxRate         Float     @default(19)
  taxAmount       Float     @default(0)
  total           Float     @default(0)

  // Payment
  paymentMethod   String    @default("")
  paymentStatus   String    @default("pending")
  transactionId   String    @default("")

  // PDF
  pdfUrl          String    @default("")

  invoiceDate     DateTime  @default(now())
  dueDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([billingEmail])
  @@index([invoiceNumber])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Media Library (central asset management)
// ──────────────────────────────────────────────
model Media {
  id            String   @id @default(cuid())
  wpMediaId     Int?     @unique
  fileName      String   @default("")   // SEO-friendly filename (editable)
  originalName  String   @default("")   // Original upload name
  title         String   @default("")
  altText       String   @default("")
  sourceUrl     String                  // Full URL to the original image
  localPath     String   @default("")   // Relative path on server
  thumbnailUrl  String   @default("")   // 150px thumbnail
  mediumUrl     String   @default("")   // 500px medium variant
  largeUrl      String   @default("")   // 1200px large variant
  webpUrl       String   @default("")   // WebP optimized version
  avifUrl       String   @default("")   // AVIF optimized version
  mimeType      String   @default("")
  width         Int      @default(0)
  height        Int      @default(0)
  fileSize      Int      @default(0)
  folder        String   @default("")   // Logical folder/category
  usedIn            String   @default("[]") // JSON: list of {type, id, field} refs
  useCount          Int      @default(0)    // Number of places this image is used
  processingStatus  String   @default("ready") // ready | pending | processing | failed
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([fileName])
  @@index([createdAt])
  @@index([folder])
  @@index([mimeType])
  @@index([useCount])
  @@index([processingStatus])
}

// ──────────────────────────────────────────────
// Email Campaigns (Kampagnen)
// ──────────────────────────────────────────────
model EmailCampaign {
  id              String    @id @default(cuid())
  name            String                          // Internal campaign name
  subject         String    @default("")          // Email subject line
  heading         String    @default("")          // Email heading (H1)
  content         String    @default("")          // HTML body content
  imageUrl        String    @default("")          // Optional hero image URL
  ctaText         String    @default("")          // CTA button text
  ctaUrl          String    @default("")          // CTA button URL

  // Targeting
  targetMode      String    @default("all")       // all, specific, segment
  targetEmails    String    @default("")          // comma-separated emails for "specific" mode
  targetSegment   String    @default("")          // JSON segment rules for "segment" mode

  // Scheduling
  scheduledAt     DateTime?                       // null = send immediately

  // Tracking
  openCount       Int       @default(0)
  clickCount      Int       @default(0)

  // Template
  templateId      String    @default("")          // template used as base

  status          String    @default("draft")     // draft, scheduled, sending, sent, failed
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  errorLog        String    @default("")          // JSON array of failed emails

  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([scheduledAt])
}

// ──────────────────────────────────────────────
// Coupons / Discount Codes
// ──────────────────────────────────────────────
model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique               // uppercase unique code
  description     String    @default("")
  discountType    String    @default("fixed")      // fixed | percentage
  discountValue   Float     @default(0)            // amount in € or %
  minOrderValue   Float     @default(0)            // minimum order subtotal
  maxUsageTotal   Int       @default(0)            // 0 = unlimited
  maxUsagePerUser Int       @default(1)            // per email
  usageCount      Int       @default(0)            // current total uses
  productSlugs    String    @default("")           // comma-separated product slugs, empty = all

  isActive        Boolean   @default(true)
  showBanner      Boolean   @default(false)        // show promo strip on site
  bannerText      String    @default("")           // custom banner text

  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usages          CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([endDate])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  email     String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([couponId, email]) // one use per email per coupon
  @@index([email])
  @@index([couponId])
}
