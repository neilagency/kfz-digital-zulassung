# ─────────────────────────────────────────────────────────
# Google Tag Manager
# ─────────────────────────────────────────────────────────
# Your GTM container ID, e.g. GTM-XXXXXXX
# Find it at: https://tagmanager.google.com → Admin → Container Settings
NEXT_PUBLIC_GTM_ID=GTM-PW5VN97M

# ─────────────────────────────────────────────────────────
# Google Analytics 4
# ─────────────────────────────────────────────────────────
# Your GA4 Measurement ID, e.g. G-XXXXXXXXXX
# Find it in GA4 → Admin → Data Streams → Web stream details
# NOTE: GA4 is configured INSIDE GTM (preferred architecture).
#       This variable is only needed if you add direct gtag.js calls
#       or use it inside event tracking utilities.
NEXT_PUBLIC_GA_ID=G-Q0VM0545GB
