# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
#
# This file documents all environment variables required for production.
# Copy this to .env.local for local development or to the server for production.
#
# Server location: /home/u104276643/env/onlineautoabmelden.env
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# Database (Turso)
# ─────────────────────────────────────────────────────────
# Your Turso database connection URL
# Get it from: https://turso.tech/app → Your Database → Connection URL
TURSO_DATABASE_URL=libsql://your-database-name.turso.io

# Your Turso authentication token
# Get it from: turso db tokens create your-database-name
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────────────────
# SMTP server hostname (e.g., smtp.hostinger.com, smtp.gmail.com)
SMTP_HOST=smtp.hostinger.com

# SMTP server port (465 for SSL, 587 for TLS)
SMTP_PORT=465

# SMTP username (usually your email address)
SMTP_USER=noreply@onlineautoabmelden.com

# SMTP password (base64 encoded for security)
# Encode your password: echo -n 'your-password' | base64
SMTP_PASS_B64=eW91ci1wYXNzd29yZC1iYXNlNjQtZW5jb2RlZA==

# ─────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────
# Secret for cron endpoint authentication (min 32 characters)
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-32-character-secret-here

# NextAuth.js secret for JWT signing (min 32 characters)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth.js canonical URL (must match your production domain)
NEXTAUTH_URL=https://onlineautoabmelden.com

# ─────────────────────────────────────────────────────────
# Payment - Mollie
# ─────────────────────────────────────────────────────────
# Mollie API key (live_... for production, test_... for testing)
# Get it from: https://www.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# Payment - PayPal
# ─────────────────────────────────────────────────────────
# PayPal client ID (from PayPal Developer Dashboard)
# Get it from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=AYourPayPalClientIdHere

# PayPal client secret (from PayPal Developer Dashboard)
PAYPAL_CLIENT_SECRET=EYourPayPalClientSecretHere

# PayPal webhook ID (optional but recommended for webhook verification)
# Get it from: https://developer.paypal.com/dashboard/webhooks
PAYPAL_WEBHOOK_ID=WH-XXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────
# Analytics
# ─────────────────────────────────────────────────────────
# Google Tag Manager container ID (e.g., GTM-XXXXXXX)
# Get it from: https://tagmanager.google.com → Admin → Container Settings
NEXT_PUBLIC_GTM_ID=GTM-PW5VN97M

# Google Analytics 4 measurement ID (e.g., G-XXXXXXXXXX)
# Get it from: https://analytics.google.com → Admin → Data Streams
# NOTE: GA4 is configured INSIDE GTM (preferred). This is optional.
NEXT_PUBLIC_GA_ID=G-Q0VM0545GB

# ─────────────────────────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────────────────────────
# Canonical site URL (must include https://)
NEXT_PUBLIC_SITE_URL=https://onlineautoabmelden.com

# Node environment (production or development)
NODE_ENV=production

# ─────────────────────────────────────────────────────────
# Optional: CDN
# ─────────────────────────────────────────────────────────
# CDN base URL for serving media assets (optional)
# If set, images will be served from this URL instead of the main domain
# CDN_BASE_URL=https://cdn.onlineautoabmelden.com

# ─────────────────────────────────────────────────────────
# Optional: Preview Mode
# ─────────────────────────────────────────────────────────
# Set to 'true' to enable preview mode (blocks search engine indexing)
# Leave unset or set to 'false' for production
# PREVIEW_MODE=false

# ─────────────────────────────────────────────────────────
# Optional: Debug Mode
# ─────────────────────────────────────────────────────────
# Set to 'true' to enable debug logging in production
# Leave unset or set to 'false' for production
# DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT NOTES
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Server Setup:
#    - Copy this file to: /home/u104276643/env/onlineautoabmelden.env
#    - Fill in all required values
#    - Ensure file permissions: chmod 600 /home/u104276643/env/onlineautoabmelden.env
#
# 2. Validation:
#    - Run: npx tsx scripts/validate-production-env.ts
#    - Fix any errors before deploying
#
# 3. Deployment:
#    - Run: bash deploy/hostinger-deploy.sh
#    - The script will copy .env from the server location
#
# 4. Cron Jobs:
#    - After first deployment, run: bash deploy/setup-cron.sh
#    - This sets up scheduled tasks (blog publishing, etc.)
#
# ═══════════════════════════════════════════════════════════════════════════
